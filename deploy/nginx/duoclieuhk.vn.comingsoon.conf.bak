# ---------------------------------------------------------------------------
# duoclieuhk.vn (+ www) → static "Coming Soon" page (/var/www/duoclieuhk)
# TLS: Let's Encrypt origin cert — Cloudflare SSL "Full (strict)" compatible.
# The investment app now lives at invest.duoclieuhk.vn.
# ---------------------------------------------------------------------------
server {
    listen 443 ssl http2;
    server_name duoclieuhk.vn www.duoclieuhk.vn;

    ssl_certificate     /etc/letsencrypt/live/duoclieuhk.vn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/duoclieuhk.vn/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/duoclieuhk;
    index index.html;
    location / { try_files $uri $uri/ /index.html; }

    add_header X-Frame-Options        "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff"     always;
    add_header Referrer-Policy        "strict-origin-when-cross-origin" always;
}

server {
    listen 80;
    listen [::]:80;
    server_name duoclieuhk.vn www.duoclieuhk.vn;
    location /.well-known/acme-challenge/ { root /var/www/html; }
    location / { return 301 https://duoclieuhk.vn$request_uri; }
}
